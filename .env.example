# ─── Database ───────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/seo-command-center
REDIS_URL=redis://localhost:6379

# ─── Authentication ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=generate-a-32-char-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── JWT ────────────────────────────────────────
JWT_SECRET=generate-a-64-char-secret-here
JWT_REFRESH_SECRET=generate-another-64-char-secret
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d

# ─── API ────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ─── Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Object Storage (S3/R2) ────────────────────
S3_BUCKET=seo-command-center
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com

# ─── Email ──────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=reports@seocommandcenter.com
